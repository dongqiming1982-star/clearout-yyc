# Frontend / Vite
VITE_USE_REMOTE_API=true
VITE_API_BASE_URL=
VITE_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key

# Vercel Serverless API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_keep_secret
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key_keep_secret
ADMIN_VIEW_KEY=choose_a_long_random_admin_password

# V23 provider email alerts
RESEND_API_KEY=your_resend_api_key
LEAD_NOTIFY_FROM=Clearout YYC <alerts@yourdomain.com>

# Optional: if you call /api/cron/process-due-leads manually with Authorization.
# Leave unset if using the Vercel Cron entry in vercel.json.
CRON_SECRET=
